// =============================================================================
// phase1/nextflow.config  — Kdr;Mef2cAHF Phase 1: per-sample QC pipeline
// Python/scanpy port. Parameter names mirror the R/Seurat pipeline exactly.
// =============================================================================
params {
    // ── 1. INPUT/OUTPUT PATHS ────────────────────────────────────────────────
    samples_yaml = "${projectDir}/../params/samples.yml"
    raw_dir      = "${projectDir}/../raw_data"
    outdir       = "${projectDir}/../results/phase1"

    // ── 2. GLOBAL DEFAULTS (applied to all samples automatically) ────────────
    defaults = [
        min_features : 200,
        max_features : 6000,
        min_counts   : 1000,
        max_counts   : 50000,
        max_mt_pct   : 10.0
    ]

    // ── 3. PER-SAMPLE QC OVERRIDES ───────────────────────────────────────────
    // Add entries keyed by sample_id to override any default above, e.g.:
    // samples = [
    //     kdr_mef2c_cko_e10: [max_counts: 80000, max_features: 7500]
    // ]
    samples = [:]

    // ── 4. DOWNSTREAM PARAMETERS ─────────────────────────────────────────────
    n_hvgs      = 2000
    target_sum  = 10000
    n_pcs       = 30
    n_neighbors = 15
    cluster_res = 0.3
    seed        = 42

    container   = "gideondocker98/kdr-mef2c-scanpy:latest"
}

// ── 5. RESOURCE MANAGEMENT ───────────────────────────────────────────────────
process {
    withLabel: 'medium' {
        cpus   = 2
        memory = '8 GB'
        time   = '2 h'
    }
    withLabel: 'high' {
        cpus     = 4
        memory   = '24 GB'
        time     = '4 h'
        maxForks = 2
    }
}

executor {
    name      = 'local'
    cpus      = 10
    queueSize = 4
}

// ── 6. EXECUTION PROFILES ────────────────────────────────────────────────────
profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = "-v ${projectDir}:${projectDir} -v ${projectDir}/../raw_data:${projectDir}/../raw_data"
        process.container = params.container
    }
    apple_silicon {
        docker.runOptions = "--platform=linux/arm64 -v ${projectDir}:${projectDir} -v ${projectDir}/../raw_data:${projectDir}/../raw_data"
    }
}

// ── 7. PIPELINE PROVENANCE ───────────────────────────────────────────────────
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt" }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.html" }
